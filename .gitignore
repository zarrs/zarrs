# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Editor files
.vscode
.idea

# Misc config files
.config

# Profiling files
*.profraw
lcov.info

# cargo-mutants
mutants.out

# MacOS files
.DS_Store

# Benchmark fixture data (generated on first run)
zarrs/benches/data/

# Large generated zarr-python compatibility matrix fixtures
zarrs/tests/data/zarr_python_compat/cast_value_matrix/
